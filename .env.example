# Solana network selection
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed apex-solana program id (override after `anchor deploy`)
VITE_PROGRAM_ID=3YKNvs1ZizwFzbraboHsxAeLSoKx4UFDwxkuNXqMkEX5

# SPL mint used as the campaign budget token
# Devnet USDC faucet mint
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# WalletConnect projectId from cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Server-side (Vercel function): Gemini API for /api/chat
GEMINI_API_KEY=

# apex-validator-solana service base URL (Demo page → /api/process)
# Local dev: http://localhost:8787
# Prod: the Railway domain of the deployed apex-validator-solana service.
VITE_VALIDATOR_URL=http://localhost:8787

# Publisher agent id used by the Demo page when an ad is clicked. Must be a
# real on-chain agent registered via newAgent() — its USDC ATA receives the
# CPA payment from the campaign vault on each settlement.
VITE_DEMO_PUBLISHER_AGENT_ID=1
